<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="KitCustomDialog" parent="@android:style/Theme.Dialog">
        <!--Dialog的windowFrame框为无-->
        <item name="android:windowFrame">@null</item>
        <!--是否浮现在activity之上-->
        <item name="android:windowIsFloating">true</item>
        <!--是否半透明-->
        <item name="android:windowIsTranslucent">true</item>
        <!--是否显示title-->
        <item name="android:windowNoTitle">true</item>
        <!--设置dialog的背景-->
        <item name="android:background">@android:color/transparent</item>
        <!--显示区域背景是否透明-->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!--就是用来控制灰度的值，当为1时，界面除了我们的dialog内容是高亮显示的，dialog以外的区域是黑色的，完全看不到其他内容，系统的默认值是0.5-->
        <item name="android:backgroundDimAmount">0.3</item>
        <!--显示区域以外是否使用黑色半透明背景-->
        <item name="android:backgroundDimEnabled">true</item>
        <!--弹出动画-->
        <item name="android:windowAnimationStyle">@style/Animation.MaterialComponents.BottomSheetDialog</item>
    </style>

    <style name="EaseDialog">
        <item name="dialogBackgroundColor">@color/colorBackground</item>
        <item name="dialogTitleTextColor">@color/colorTitleText</item>
        <item name="dialogMainTextColor">@color/colorMainText</item>
        <item name="dialogPositiveTextColor">@color/colorPositiveTextColor</item>
        <item name="dialogCancelTextColor">@color/colorMainText</item>
        <item name="dialogPressBackgroundColor">@color/colorPress</item>
        <item name="dialogRadius">@dimen/dialog_radius</item>
    </style>
</resources>